---
interface Props {
	title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Brandon Naylor Portfolio" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,700;1,300&display=swap" rel="stylesheet">
	</head>
	<body>
		<header class="site-header">
			<nav class="nav-menu">
				<a href="/" class={currentPath === "/" ? "nav-link active" : "nav-link"}>Home</a>
				<a href="/portfolio" class={currentPath === "/portfolio" || currentPath === "/portfolio/" ? "nav-link active" : "nav-link"}>Portfolio</a>
				<a href="/experience" class={currentPath === "/experience" || currentPath === "/experience/" ? "nav-link active" : "nav-link"}>Experience</a>
				<a href="/contact" class={currentPath === "/contact" || currentPath === "/contact/" ? "nav-link active" : "nav-link"}>Contact</a>
			</nav>
		</header>

		<canvas id="global-wave-canvas"></canvas>

		<div class="page-layout-root">
			<slot />
		</div>

		<script>
			const canvas = document.getElementById('global-wave-canvas') as HTMLCanvasElement;
			const ctx = canvas.getContext('2d');

			function resizeCanvas() {
				if (canvas) {
					canvas.width = window.innerWidth;
					canvas.height = window.innerHeight;
				}
			}
			resizeCanvas();
			window.addEventListener('resize', resizeCanvas);

			const waveCount = 22;
			let increment = 0;

			const particles: any[] = [];
			
			// 18 Circle particles
			for (let i = 0; i < 18; i++) {
				particles.push({
					x: Math.random() * window.innerWidth,
					y: Math.random() * window.innerHeight,
					radius: Math.random() * 5 + 2,
					speed: Math.random() * 0.15 + 0.1,
					offset: Math.random() * Math.PI * 2,
					type: 'circle'
				});
			}

			// 12 Plus particles
			for (let i = 0; i < 12; i++) {
				particles.push({
					x: Math.random() * window.innerWidth,
					y: Math.random() * window.innerHeight,
					size: Math.random() * 6 + 4,
					speed: Math.random() * 0.12 + 0.05,
					offset: Math.random() * Math.PI * 2,
					type: 'plus'
				});
			}

			function animate() {
				if (!ctx || !canvas) return;
				
				ctx.fillStyle = '#120924';
				ctx.fillRect(0, 0, canvas.width, canvas.height);
				
				const radialGlow = ctx.createRadialGradient(canvas.width/2, canvas.height/2, 10, canvas.width/2, canvas.height/2, canvas.width);
				radialGlow.addColorStop(0, '#2c1654');
				radialGlow.addColorStop(1, '#120924');
				ctx.fillStyle = radialGlow;
				ctx.fillRect(0, 0, canvas.width, canvas.height);

				const brightnessModifier = 0.7 + Math.sin(increment * 0.3) * 0.3;

				particles.forEach(p => {
					p.y -= p.speed;
					if (p.y < -10) p.y = canvas.height + 10;
					const currentX = p.x + Math.sin(increment * 0.5 + p.offset) * 15;

					if (p.type === 'circle') {
						ctx.beginPath();
						ctx.arc(currentX, p.y, p.radius, 0, Math.PI * 2);
						ctx.fillStyle = `rgba(188, 52, 164, ${0.45 * brightnessModifier})`;
						ctx.fill();
					} else {
						ctx.beginPath();
						ctx.moveTo(currentX - p.size, p.y);
						ctx.lineTo(currentX + p.size, p.y);
						ctx.moveTo(currentX, p.y - p.size);
						ctx.lineTo(currentX, p.y + p.size);
						ctx.strokeStyle = `rgba(139, 92, 246, ${0.65 * brightnessModifier})`;
						ctx.lineWidth = p.size * 0.45; 
						ctx.stroke();
					}
				});

				if (window.location.pathname === '/') {
					ctx.lineWidth = 1.5;
					for (let i = 0; i < waveCount; i++) {
						ctx.beginPath();
						const progress = i / waveCount;
						const violetAlpha = (1 - progress * 0.7) * brightnessModifier;
						const magentaAlpha = (0.9 - progress * 0.6) * brightnessModifier;

						const gradient = ctx.createLinearGradient(0, 0, canvas.width * 0.6, canvas.height);
						gradient.addColorStop(0, `rgba(139, 92, 246, ${violetAlpha})`);
						gradient.addColorStop(0.5, `rgba(217, 70, 239, ${magentaAlpha})`);
						gradient.addColorStop(1, 'rgba(12, 9, 36, 0)');
						ctx.strokeStyle = gradient;

						for (let x = 0; x < canvas.width * 0.7; x += 5) {
							const baseSine = Math.sin(x * 0.003 + increment + (i * 0.07));
							const secondarySine = Math.cos(x * 0.0015 - increment * 0.5 + (i * 0.03));
							const yOffset = (canvas.height * 0.35) + (i * 12);
							const y = yOffset + (baseSine * secondarySine * 140);
							if (x === 0) ctx.moveTo(x, y);
							else ctx.lineTo(x, y);
						}
						ctx.stroke();
					}
				}

				increment += 0.004;
				requestAnimationFrame(animate);
			}
			animate();
		</script>
	</body>
</html>

<style is:global>
	html, body {
		margin: 0;
		padding: 0;
		width: 100%;
		height: 100%;
		background-color: #120924;
		overflow-x: hidden;
	}

	.site-header {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		z-index: 100;
		display: flex;
		justify-content: center;
		padding: 1.5rem 0;
		/* Updated back to a clean vertical gradient fade with fine hardware-accelerated blur */
		background: linear-gradient(to bottom, rgba(18, 9, 36, 0.85) 0%, rgba(18, 9, 36, 0) 100%);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
	}

	.nav-menu { display: flex; gap: 3rem; }
	
	.nav-link {
		font-family: 'Poppins', sans-serif;
		color: #ffffff !important;
		text-decoration: none !important;
		font-size: 1.1rem;
		opacity: 0.7;
		transition: 0.3s ease;
	}
	.nav-link:hover, .nav-link.active { opacity: 1; }
	.nav-link.active { border-bottom: 2px solid #bc34a4; padding-bottom: 4px; }

	#global-wave-canvas {
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		z-index: 1;
		pointer-events: none;
	}

	.page-layout-root {
		position: relative;
		z-index: 5;
		width: 100%;
		min-height: 100vh;
	}

	@media (max-width: 768px) {
		.nav-menu { gap: 1.5rem; }
		.nav-link { font-size: 0.9rem; }
	}
</style>