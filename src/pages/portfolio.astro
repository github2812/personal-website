---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Brandon Naylor | Portfolio">
	<div class="split-page-wrapper">
		
		<section class="portfolio-hero">
			<div class="hero-content-block">
				<h1 class="page-title">Portfolio</h1>
				<p class="hero-description-text">desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc </p>
				
				<div class="jump-links">
					<a href="#cs" class="jump-btn">CS Projects</a>
					<a href="#music" class="jump-btn">Music Projects</a>
					<a href="#passion" class="jump-btn">Passion Projects</a>
				</div>
			</div>
		</section>
		
		<div class="light-page-content">
			<div class="page-content-container">
				
				<section id="cs" class="portfolio-section">
					<h2 class="section-heading">Computer Science Projects</h2>
					<div class="project-grid">
						<div class="project-card">
							<div class="image-side"></div>
							<div class="text-side">
								<h3 class="project-title">CS Project One</h3>
								<h4 class="project-subtitle">Tech Stack Used</h4>
								<p class="template-p">desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc </p>
							</div>
						</div>
						<div class="project-card">
							<div class="image-side"></div>
							<div class="text-side">
								<h3 class="project-title">CS Project Two</h3>
								<h4 class="project-subtitle">Tech Stack Used</h4>
								<p class="template-p">desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc </p>
							</div>
						</div>
					</div>
				</section>

				<section id="music" class="portfolio-section">
					<h2 class="section-heading">Music Projects</h2>
					<div class="project-grid">
						<div class="project-card">
							<div class="image-side"></div>
							<div class="text-side">
								<h3 class="project-title">Music Project One</h3>
								<h4 class="project-subtitle">Composition / Arrangement</h4>
								<p class="template-p">desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc </p>
							</div>
						</div>
						<div class="project-card">
							<div class="image-side"></div>
							<div class="text-side">
								<h3 class="project-title">Music Project Two</h3>
								<h4 class="project-subtitle">Composition / Arrangement</h4>
								<p class="template-p">desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc </p>
							</div>
						</div>
					</div>
				</section>

				<section id="passion" class="portfolio-section">
					<h2 class="section-heading">Passion Projects</h2>
					<div class="project-grid">
						<div class="project-card">
							<div class="image-side"></div>
							<div class="text-side">
								<h3 class="project-title">Passion Project One</h3>
								<h4 class="project-subtitle">Personal Endeavor</h4>
								<p class="template-p">desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc </p>
							</div>
						</div>
						<div class="project-card">
							<div class="image-side"></div>
							<div class="text-side">
								<h3 class="project-title">Passion Project Two</h3>
								<h4 class="project-subtitle">Personal Endeavor</h4>
								<p class="template-p">desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc </p>
							</div>
						</div>
					</div>
				</section>
				
			</div>
		</div>
	</div>
</Layout>

<style>
	.split-page-wrapper { width: 100%; display: flex; flex-direction: column; }

	.portfolio-hero {
		height: 100vh; width: 100%; display: flex; align-items: center; justify-content: center; text-align: center; position: relative; z-index: 5; padding: 0 2rem;
	}

	.hero-content-block { max-width: 750px; width: 100%; display: flex; flex-direction: column; align-items: center; }

	.page-title { 
		font-size: 3.8rem; font-weight: 700; margin: 0 0 1.5rem 0; letter-spacing: 1px; color: #ffffff;
		text-shadow: 0 4px 12px rgba(0, 0, 0, 0.6); /* Lowered slightly for cleaner anti-aliasing text profiles */
	}

	.hero-description-text {
		font-size: 1.15rem; line-height: 1.6; color: rgba(255, 255, 255, 0.85); margin: 0 0 3rem 0; max-width: 620px; text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5); text-wrap: balance;
	}

	.jump-links { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
	.jump-btn {
		background: rgba(255, 255, 255, 0.04); color: #ffffff; border: 1px solid rgba(255, 255, 255, 0.15); padding: 0.8rem 1.6rem; border-radius: 30px; text-decoration: none; font-weight: 600; transition: all 0.25s ease;
	}
	.jump-btn:hover { background: rgba(188, 52, 164, 0.1); border-color: #bc34a4; transform: translateY(-2px); }
	
	.light-page-content {
		background-color: #ffffff; color: #1a1a2e; width: 100%; display: flex; justify-content: center; padding: 6rem 2rem; position: relative; z-index: 10;
	}

	.page-content-container { max-width: 900px; width: 100%; }
	.portfolio-section { margin-bottom: 6rem; scroll-margin-top: 140px; }
	.portfolio-section:last-child { margin-bottom: 0; }
	
	/* Refactored Section Titles to Dark Purple */
	.section-heading { font-size: 2.2rem; font-weight: 700; color: #2a1454; margin-bottom: 2rem; border-bottom: 2px solid #f0f0f5; padding-bottom: 0.5rem; }
	.project-grid { display: flex; flex-direction: column; gap: 2.5rem; }
	
	.project-card { 
		display: flex; background: #ffffff; border: 1px solid #f0f0f5; border-radius: 12px; overflow: hidden; min-height: 220px; box-shadow: 0 5px 20px rgba(0, 0, 0, 0.04); transition: transform 0.3s ease;
	}
	.project-card:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(188, 52, 164, 0.05); border-color: #e2e2ec; }

	.image-side { flex: 0 0 35%; background: #fdfdff; border-right: 1px solid #f0f0f5; }
	
	/* Lock details into neutral black and clean slate/gray shades */
	.text-side { flex: 1; padding: 2.2rem; display: flex; flex-direction: column; justify-content: center; }
	.project-title { margin: 0 0 0.35rem 0; font-size: 1.6rem; font-weight: 700; color: #111111; }
	.project-subtitle { margin: 0 0 1rem 0; color: #555555; font-size: 0.9rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; }
	.template-p { color: #555555; line-height: 1.7; margin: 0; font-size: 1.05rem; }

	@media (max-width: 768px) { .page-title { font-size: 2.8rem; } .project-card { flex-direction: column; } .image-side { min-height: 180px; width: 100%; } }
</style>