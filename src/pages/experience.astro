---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Brandon Naylor | Experience">
	<div class="split-page-wrapper">
		
		<section class="experience-hero">
			<div class="hero-content-block">
				<h1 class="page-title">Experience</h1>
				<p class="hero-description-text">This contains a list of relevant skills, grouped into categories, as well as work/volunteer experience from high school to present.</p>

				<div class="jump-links">
					<a href="#skills" class="jump-btn">Skills</a>
					<a href="#work" class="jump-btn">Work/Volunteer</a>
				</div>
			</div>
		</section>

		<div class="light-page-content">
			<div class="page-content-container">
				
				<section id="skills" class="experience-section">
					<h2 class="section-heading">Skills</h2>
					<div class="skills-grid">
						
						<div class="skill-category">
							<h3>Technology</h3>
							<ul>
								<li>C++</li>
								<li>C#</li>
								<li>JavaScript</li>
								<li>HTML5</li>
								<li>Unity Game Engine</li>
								<li>Astro Development</li>
								<li>Cloudflare Deployment</li>
								<li>GitHub</li>
								<li>Excel/Sheets</li>
								<li>Google Suite</li>
								<li>Canva Design</li>
								<li>Final Cut Pro</li>
								<li>iMovie</li>
							</ul>
						</div>
						
						<div class="skill-category">
							<h3>Music</h3>
							<ul>
								<li>Drumset/Percussion Performance</li>
								<li>Percussion Instruction</li>
								<li>Logic Pro Composition/Production</li>
								<li>MuseScore Composition/Notation</li>
								<li>Audio Engineering</li>
								<li>Live Mixing</li>
							</ul>
						</div>
						
						<div class="skill-category">
							<h3>Miscellaneous</h3>
							<ul>
								<li>Teaching</li>
								<li>Cooking/Baking</li>
								<li>Lego Construction</li>
								<li>Flexibility</li>
								<li>Organization</li>
								<li>Patience</li>
							</ul>
						</div>
						
					</div>
				</section>

				<section id="work" class="experience-section">
					<h2 class="section-heading">Work & Volunteer Experience</h2>
					<div class="timeline">
						<div class="timeline-item">
							<div class="time-meta">
								<span class="role">Instructor</span>
								<span class="date">Present</span>
							</div>
							<p class="template-p">desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc desc </p>
						</div>
					</div>
				</section>

			</div>
		</div>
	</div>
</Layout>

<style>
	.split-page-wrapper { width: 100%; display: flex; flex-direction: column; }
	
	.experience-hero {
		height: 100dvh; width: 100%; display: flex; align-items: center; justify-content: center; text-align: center; position: relative; z-index: 5; padding: 0 2rem;
	}

	.hero-content-block { position: relative; z-index: 5; max-width: 750px; width: 100%; display: flex; flex-direction: column; align-items: center; }

	/* FLUID TYPOGRAPHY SCALING */
	.page-title { 
		font-size: clamp(3.2rem, 10vw, 5rem); font-weight: 700; margin: 0 0 1.5rem 0; letter-spacing: 1px; color: #ffffff;
		text-shadow: 0 4px 12px rgba(0, 0, 0, 0.6); animation: scaleEase 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}

	.hero-description-text {
		font-size: 1.15rem; line-height: 1.6; color: rgba(255, 255, 255, 0.85); margin: 0 0 3rem 0; max-width: 620px; text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5); text-wrap: balance;
		animation: scaleEase 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards; opacity: 0;
	}
	
	.jump-links { display: flex; gap: 1rem; animation: scaleEase 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards; opacity: 0; }
	.jump-btn { 
		background: rgba(255, 255, 255, 0.04); color: #ffffff; border: 1px solid rgba(255, 255, 255, 0.15); padding: 0.8rem 1.6rem; border-radius: 30px; text-decoration: none; font-weight: 600; transition: all 0.25s ease; 
	}
	.jump-btn:hover { background: rgba(188, 52, 164, 0.1); border-color: #bc34a4; transform: translateY(-2px); }

	.light-page-content {
		background-color: #ffffff; color: #1a1a2e; width: 100%; display: flex; justify-content: center; padding: 6rem 2rem; position: relative; z-index: 10;
	}

	.page-content-container { max-width: 920px; width: 100%; }
	.experience-section { margin-bottom: 6rem; scroll-margin-top: 140px; }
	.experience-section:last-child { margin-bottom: 0; }
	
	.section-heading { font-size: 2.2rem; font-weight: 700; color: #2a1454; margin-bottom: 2.5rem; border-bottom: 2px solid #f0f0f5; padding-bottom: 0.5rem; }

	.timeline { border-left: 2px solid #f0f0f5; padding-left: 2.5rem; max-width: 800px; margin-left: auto; margin-right: auto; }
	.timeline-item { position: relative; margin-bottom: 3.5rem; }
	.timeline-item::before { content: ''; position: absolute; left: calc(-2.5rem - 7px); top: 6px; width: 12px; height: 12px; border-radius: 50%; background: #bc34a4; }
	.time-meta { display: flex; justify-content: space-between; margin-bottom: 0.6rem; }
	
	.role { font-weight: 700; font-size: 1.3rem; color: #111111; }
	.date { color: #555555; font-weight: 600; }
	.template-p { color: #555555; line-height: 1.7; margin: 0; font-size: 1.05rem; }
	
	.skills-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2.5rem; align-items: start; }
	.skill-category { background: #ffffff; border: 1px solid #f0f0f5; border-radius: 12px; padding: 2.2rem 2rem; box-shadow: 0 4px 16px rgba(0,0,0,0.02); }
	
	.skill-category h3 { font-size: 1.4rem; font-weight: 700; color: #2a1454; margin: 0 0 1.5rem 0; border-bottom: 2px solid #f0f0f5; padding-bottom: 0.5rem; letter-spacing: 0.5px; }
	.skill-category ul { list-style: none; padding: 0; margin: 0; }
	
	.skill-category li { 
		font-size: 1.05rem; 
		margin-bottom: 0.8rem; 
		color: #555555; 
		display: flex; 
		align-items: center;
		line-height: 1.45; 
	}
	
	.skill-category li::before { 
		content: '▹'; 
		color: #bc34a4; 
		margin-right: 10px; 
		font-weight: bold; 
		flex-shrink: 0; 
	}

	@keyframes scaleEase { from { opacity: 0; transform: scale(0.92); } to { opacity: 1; transform: scale(1); } }

	@media (max-width: 990px) { .skills-grid { grid-template-columns: 1fr; max-width: 420px; margin: 0 auto; } }
	@media (max-width: 768px) { .time-meta { flex-direction: column; gap: 0.25rem; } }
</style>