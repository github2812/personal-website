---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Scales Practice Engine">
    <div class="split-page-wrapper">
        
        <section class="portfolio-hero">
            <div class="hero-content-block">
                <h1 class="page-title">Scales</h1>
                <p class="hero-description-text">Practice your major scales here!</p>
                <button id="go-btn" class="go-action-btn">
                    Go!
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
                </button>
            </div>
        </section>
        
        <div class="light-page-content" id="practice-area">
            <div id="confetti-container"></div>

            <div class="page-content-container">
                
                <section id="main-content-anchor" class="global-instructions-section">
                    <div class="uniform-card-panel">
                        <div class="instructions-header">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                            <h2>Instructions</h2>
                        </div>
                        <div class="instructions-body-content">
                            <div class="instruction-mode-block">
                                <h3 class="mode-title-tag">Practice Mode:</h3>
                                <p class="mode-desc-text">Select your target scale from the Master Checklist below. The Demo Keyboard will automatically highlight all the notes belonging to that major scale.</p>
                                <p class="mode-desc-text">Use the Personal Keyboard to work out the scales. It will have no effect on your score/checklist in practice mode.</p>
                            </div>
                            
                            <div class="instruction-mode-block">
                                <h3 class="mode-title-tag">Test Mode:</h3>
                                <p class="mode-desc-text">Once you know the scale, switch to test mode. This will hide the demo keyboard.</p>
                                <p class="mode-desc-text">Use your Personal Keyboard to play the ascending scale. (Ex: C4-&gt;C5) This will increase your score and check the scale off.</p>
                                <p class="mode-desc-text">Feel free to complete each scale as many times as you want. This will increase the score!</p>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="controls-section">
                    <div class="uniform-card-panel">
                        <div class="control-row">
                            <div class="control-field">
                                <label class="field-label">Choose Assignment Mode</label>
                                <div class="mode-options">
                                    <label class="mode-radio">
                                        <input type="radio" name="game-mode" value="practice" checked />
                                        <span class="radio-text">Practice Mode (Demo On)</span>
                                    </label>
                                    <label class="mode-radio">
                                        <input type="radio" name="game-mode" value="test" />
                                        <span class="radio-text">Test Mode (Demo Off / Score Tracker On)</span>
                                    </label>
                                </div>
                            </div>

                            <div class="control-field score-field">
                                <span class="field-label">Score</span>
                                <div class="score-display-box" id="score-display">0</div>
                            </div>
                        </div>

                        <div class="passed-history-row">
                            <span class="field-label">Select a Scale to Practice / Test</span>
                            <div id="master-scales-checklist" class="checklist-grid">
                                <div class="checklist-item is-active" data-scale-id="0"><span class="check-indicator"></span>C Major</div>
                                <div class="checklist-item" data-scale-id="1"><span class="check-indicator"></span>C# / Db Major</div>
                                <div class="checklist-item" data-scale-id="2"><span class="check-indicator"></span>D Major</div>
                                <div class="checklist-item" data-scale-id="3"><span class="check-indicator"></span>D# / Eb Major</div>
                                <div class="checklist-item" data-scale-id="4"><span class="check-indicator"></span>E Major</div>
                                <div class="checklist-item" data-scale-id="5"><span class="check-indicator"></span>F Major</div>
                                <div class="checklist-item" data-scale-id="6"><span class="check-indicator"></span>F# / Gb Major</div>
                                <div class="checklist-item" data-scale-id="7"><span class="check-indicator"></span>G Major</div>
                                <div class="checklist-item" data-scale-id="8"><span class="check-indicator"></span>G# / Ab Major</div>
                                <div class="checklist-item" data-scale-id="9"><span class="check-indicator"></span>A Major</div>
                                <div class="checklist-item" data-scale-id="10"><span class="check-indicator"></span>A# / Bb Major</div>
                                <div class="checklist-item" data-scale-id="11"><span class="check-indicator"></span>B Major</div>
                            </div>
                        </div>
                    </div>
                </section>

                <section id="demo-section" class="keyboard-section">
                    <div class="uniform-card-panel">
                        <div class="keyboard-header-wrapper">
                            <div class="header-text-side">
                                <h2 class="keyboard-title">Demo Keyboard</h2>
                            </div>
                            <button id="play-demo-btn" class="demo-action-btn">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                                Play Demo
                            </button>
                        </div>
                        
                        <div class="piano-wrapper">
                            <div class="piano disabled-piano demo-variant" id="demo-piano">
                                <div class="key white-key" data-index="0"><span class="note-name-tag">C4</span></div>
                                <div class="key white-key" data-index="2"><span class="note-name-tag">D4</span></div>
                                <div class="key white-key" data-index="4"><span class="note-name-tag">E4</span></div>
                                <div class="key white-key" data-index="5"><span class="note-name-tag">F4</span></div>
                                <div class="key white-key" data-index="7"><span class="note-name-tag">G4</span></div>
                                <div class="key white-key" data-index="9"><span class="note-name-tag">A4</span></div>
                                <div class="key white-key" data-index="11"><span class="note-name-tag">B4</span></div>
                                <div class="key white-key" data-index="12"><span class="note-name-tag">C5</span></div>
                                <div class="key white-key" data-index="14"><span class="note-name-tag">D5</span></div>
                                <div class="key white-key" data-index="16"><span class="note-name-tag">E5</span></div>
                                <div class="key white-key" data-index="17"><span class="note-name-tag">F5</span></div>
                                <div class="key white-key" data-index="19"><span class="note-name-tag">G5</span></div>
                                <div class="key white-key" data-index="21"><span class="note-name-tag">A5</span></div>
                                <div class="key white-key" data-index="23"><span class="note-name-tag">B5</span></div>
                                <div class="key white-key" data-index="24"><span class="note-name-tag">C6</span></div>

                                <div class="key black-key" data-index="1" style="left: 6.6667%;"><span class="note-name-tag">C#4<br class="label-split">Db4</span></div>
                                <div class="key black-key" data-index="3" style="left: 13.3333%;"><span class="note-name-tag">D#4<br class="label-split">Eb4</span></div>
                                <div class="key black-key" data-index="6" style="left: 26.6667%;"><span class="note-name-tag">F#4<br class="label-split">Gb4</span></div>
                                <div class="key black-key" data-index="8" style="left: 33.3333%;"><span class="note-name-tag">G#4<br class="label-split">Ab4</span></div>
                                <div class="key black-key" data-index="10" style="left: 40.0000%;"><span class="note-name-tag">A#4<br class="label-split">Bb4</span></div>
                                <div class="key black-key" data-index="13" style="left: 53.3333%;"><span class="note-name-tag">C#5<br class="label-split">Db5</span></div>
                                <div class="key black-key" data-index="15" style="left: 60.0000%;"><span class="note-name-tag">D#5<br class="label-split">Eb5</span></div>
                                <div class="key black-key" data-index="18" style="left: 73.3333%;"><span class="note-name-tag">F#5<br class="label-split">Gb5</span></div>
                                <div class="key black-key" data-index="20" style="left: 80.0000%;"><span class="note-name-tag">G#5<br class="label-split">Ab5</span></div>
                                <div class="key black-key" data-index="22" style="left: 86.6667%;"><span class="note-name-tag">A#5<br class="label-split">Bb5</span></div>
                            </div>
                        </div>
                    </div>
                </section>

                <section id="personal-section" class="keyboard-section">
                    <div class="uniform-card-panel">
                        <div class="keyboard-header-wrapper">
                            <h2 class="keyboard-title">Personal Keyboard</h2>
                        </div>
                        
                        <div class="piano-wrapper">
                            <div class="piano interactive-variant" id="personal-piano">
                                <div class="key white-key" data-index="0"></div>
                                <div class="key white-key" data-index="2"></div>
                                <div class="key white-key" data-index="4"></div>
                                <div class="key white-key" data-index="5"></div>
                                <div class="key white-key" data-index="7"></div>
                                <div class="key white-key" data-index="9"></div>
                                <div class="key white-key" data-index="11"></div>
                                <div class="key white-key" data-index="12"></div>
                                <div class="key white-key" data-index="14"></div>
                                <div class="key white-key" data-index="16"></div>
                                <div class="key white-key" data-index="17"></div>
                                <div class="key white-key" data-index="19"></div>
                                <div class="key white-key" data-index="21"></div>
                                <div class="key white-key" data-index="23"></div>
                                <div class="key white-key" data-index="24"></div>

                                <div class="key black-key" data-index="1" style="left: 6.6667%;"></div>
                                <div class="key black-key" data-index="3" style="left: 13.3333%;"></div>
                                <div class="key black-key" data-index="6" style="left: 26.6667%;"></div>
                                <div class="key black-key" data-index="8" style="left: 33.3333%;"></div>
                                <div class="key black-key" data-index="10" style="left: 40.0000%;"></div>
                                <div class="key black-key" data-index="13" style="left: 53.3333%;"></div>
                                <div class="key black-key" data-index="15" style="left: 60.0000%;"></div>
                                <div class="key black-key" data-index="18" style="left: 73.3333%;"></div>
                                <div class="key black-key" data-index="20" style="left: 80.0000%;"></div>
                                <div class="key black-key" data-index="22" style="left: 86.6667%;"></div>
                            </div>
                        </div>

                        <div id="instruction-panel" class="instruction-box mode-hidden">
                            <div class="instruction-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                            </div>
                            <div id="instruction-text" class="instruction-content">
                                Loading assignment data...
                            </div>
                        </div>
                    </div>
                </section>
                
            </div>
        </div>
    </div>
</Layout>

<script>
    // FIX: Moved scaleNamesLookup to the global client-side scope so all functions can safely resolve it
    const scaleNamesLookup = [
        "C Major", "C# / Db Major", "D Major", "D# / Eb Major", "E Major", "F Major",
        "F# / Gb Major", "G Major", "G# / Ab Major", "A Major", "A# / Bb Major", "B Major"
    ];

    document.addEventListener("DOMContentLoaded", () => {
        
        // --- Full-Screen Scroll Anchoring ---
        document.getElementById('go-btn')?.addEventListener('click', () => {
            document.getElementById('main-content-anchor')?.scrollIntoView({ behavior: 'smooth' });
        });

        // --- Audio Engine Frequency Matrix ---
        const frequencies: number[] = [
            261.63, 277.18, 293.66, 311.13, 329.63, 349.23, 369.99, 392.00, 415.30, 440.00, 466.16, 493.88, // Octave 4
            523.25, 554.37, 587.33, 622.25, 659.25, 698.46, 739.99, 783.99, 830.61, 880.00, 932.33, 987.77, // Octave 5
            1046.50 // C6 Boundary
        ];

        const flatFriendlyLookup = ["C4", "Db4", "D4", "Eb4", "E4", "F4", "Gb4", "G4", "Ab4", "A4", "Bb4", "B4"];
        const sharpFriendlyLookup = ["C4", "C#4", "D4", "D#4", "E4", "F4", "F#4", "G4", "G#4", "A4", "A#4", "B4"];
        const targetScaleSteps: number[] = [0, 2, 4, 5, 7, 9, 11, 12];

        // Global State Mechanics
        let currentScaleId: number = 0;
        let audioCtx: AudioContext | null = null;
        let score: number = 0;
        let userSequence: number[] = [];
        let scalePlaybackTimeout: ReturnType<typeof setTimeout> | null = null;
        let errorResetTimeout: ReturnType<typeof setTimeout> | null = null;
        let successResetTimeout: ReturnType<typeof setTimeout> | null = null;
        let scaleCompletedFlag = false;

        function initAudio(): void {
            if (!audioCtx) {
                const AudioContextClass = window.AudioContext || (window as any).webkitAudioContext;
                audioCtx = new AudioContextClass();
            }
            if (audioCtx && audioCtx.state === 'suspended') {
                audioCtx.resume();
            }
        }

        function playNote(freq: number, duration: number = 0.4): void {
            initAudio();
            if (!audioCtx) return;

            const osc = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            
            osc.type = 'triangle';
            osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
            
            gainNode.gain.setValueAtTime(0.35, audioCtx.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + duration);
            
            osc.connect(gainNode);
            gainNode.connect(audioCtx.destination);
            
            osc.start();
            osc.stop(audioCtx.currentTime + duration);
        }

        // --- UI Visibility State Elements ---
        const modeRadios = document.querySelectorAll('input[name="game-mode"]');
        const demoSection = document.getElementById('demo-section');
        const instructionPanel = document.getElementById('instruction-panel');
        const instructionText = document.getElementById('instruction-text');
        const checklistItems = document.querySelectorAll('#master-scales-checklist .checklist-item');

        // --- Auto Highlighting Structural Scale Membership Logic ---
        function updateDemoScaleHighlights(): void {
            document.querySelectorAll('#demo-piano .key').forEach(k => {
                k.classList.remove('scale-member');
                k.classList.remove('highlight-active');
            });

            const activeScaleIndices = targetScaleSteps.map(step => currentScaleId + step);

            activeScaleIndices.forEach(idx => {
                const targetKey = document.querySelector(`#demo-piano .key[data-index="${idx}"]`);
                if (targetKey) {
                    targetKey.classList.add('scale-member');
                }
            });
        }

        // --- Dynamic Instructions Engine ---
        function updateInstructionsDashboard(statusType?: 'error' | 'success'): void {
            if (!instructionText) return;
            
            if (statusType !== 'error' && errorResetTimeout) {
                clearTimeout(errorResetTimeout);
            }

            const currentScaleName = scaleNamesLookup[currentScaleId];
            const useFlats = [1, 3, 5, 6, 8, 10].includes(currentScaleId);
            const rootFriendlyName = useFlats ? flatFriendlyLookup[currentScaleId] : sharpFriendlyLookup[currentScaleId];

            if (statusType === 'error') {
                instructionText.innerHTML = `<span class="text-alert-danger">Wrong note, try again. 👍</span>`;
                return;
            }

            if (scaleCompletedFlag) {
                instructionText.innerHTML = `<span class="text-alert-success">Success! Passed ${currentScaleName}! 🎉 Pick another scale, or run this one again.</span>`;
                return;
            }

            if (userSequence.length === 0) {
                instructionText.innerHTML = `Play <strong class="highlight-token">${rootFriendlyName}</strong> to start the ascending root-to-root scale.`;
            } else {
                instructionText.innerHTML = `Keep playing the ascending <strong class="highlight-token">${currentScaleName}</strong> scale.`;
            }
        }

        // --- Checklist Target Router Engine ---
        function changeActiveScale(scaleId: number): void {
            currentScaleId = scaleId;
            
            checklistItems.forEach(item => {
                const idAttr = item.getAttribute('data-scale-id');
                if (idAttr && parseInt(idAttr) === currentScaleId) {
                    item.classList.add('is-active');
                } else {
                    item.classList.remove('is-active');
                }
            });

            userSequence = [];
            scaleCompletedFlag = false;
            if (scalePlaybackTimeout) clearTimeout(scalePlaybackTimeout);
            if (successResetTimeout) clearTimeout(successResetTimeout);
            
            cleanDemoPlaybackHighlightsOnly();
            cleanPersonalKeyboardFeedbackStates();
            updateDemoScaleHighlights();
            updateInstructionsDashboard();
        }

        checklistItems.forEach(item => {
            item.addEventListener('click', () => {
                const idAttr = item.getAttribute('data-scale-id');
                if (idAttr) {
                    changeActiveScale(parseInt(idAttr));
                }
            });
        });

        function cleanPersonalKeyboardFeedbackStates(): void {
            document.querySelectorAll('#personal-piano .key').forEach(k => {
                k.classList.remove('test-correct', 'test-wrong', 'test-revealed');
            });
        }

        function updateVisibilityMode(): void {
            const activeModeEl = document.querySelector('input[name="game-mode"]:checked') as HTMLInputElement | null;
            const activeMode = activeModeEl ? activeModeEl.value : 'practice';
            
            cleanPersonalKeyboardFeedbackStates();
            if (scalePlaybackTimeout) clearTimeout(scalePlaybackTimeout);
            if (successResetTimeout) clearTimeout(successResetTimeout);

            if (activeMode === 'test') {
                demoSection?.classList.add('mode-hidden');
                instructionPanel?.classList.remove('mode-hidden');
                cleanDemoPlaybackHighlightsOnly();
            } else {
                demoSection?.classList.remove('mode-hidden');
                instructionPanel?.classList.add('mode-hidden');
                updateDemoScaleHighlights();
            }
            userSequence = [];
            scaleCompletedFlag = false;
            updateInstructionsDashboard();
        }

        modeRadios.forEach(radio => radio.addEventListener('change', updateVisibilityMode));

        // --- Demo Playback Engine Routine ---
        function cleanDemoPlaybackHighlightsOnly(): void {
            document.querySelectorAll('#demo-piano .key').forEach(k => k.classList.remove('highlight-active'));
        }

        function playScaleDemoRun(): void {
            if (scalePlaybackTimeout) clearTimeout(scalePlaybackTimeout);
            cleanDemoPlaybackHighlightsOnly();

            let currentStep = 0;
            const msInterval = 420;

            function performStep(): void {
                if (currentStep >= targetScaleSteps.length) {
                    cleanDemoPlaybackHighlightsOnly();
                    return;
                }

                const targetIndex = currentScaleId + targetScaleSteps[currentStep];
                if (targetIndex < frequencies.length) {
                    playNote(frequencies[targetIndex], 0.4);

                    cleanDemoPlaybackHighlightsOnly();
                    const targetDOMKey = document.querySelector(`#demo-piano .key[data-index="${targetIndex}"]`);
                    targetDOMKey?.classList.add('highlight-active');
                }

                currentStep++;
                scalePlaybackTimeout = setTimeout(performStep, msInterval);
            }
            performStep();
        }

        document.getElementById('play-demo-btn')?.addEventListener('click', playScaleDemoRun);

        // --- Confetti Animation Particle System Module ---
        function triggerConfettiBurst(): void {
            const holder = document.getElementById('confetti-container');
            if (!holder) return;

            const colors = ['#bc34a4', '#2a1454', '#22c55e', '#38bdf8', '#fbbf24', '#f43f5e'];
            for (let i = 0; i < 45; i++) {
                const particle = document.createElement('div');
                particle.className = 'confetti-piece';
                
                const randColor = colors[Math.floor(Math.random() * colors.length)];
                const leftPos = 35 + Math.random() * 30; 
                const driftX = (Math.random() - 0.5) * 400;
                const dropY = 200 + Math.random() * 250;

                particle.style.backgroundColor = randColor;
                particle.style.left = `${leftPos}%`;
                particle.style.setProperty('--drift-x', `${driftX}px`);
                particle.style.setProperty('--drop-y', `${dropY}px`);
                
                holder.appendChild(particle);
                setTimeout(() => particle.remove(), 1200);
            }
        }

        // --- Interactive Input Processing Logic ---
        document.querySelectorAll('#personal-piano .key').forEach(key => {
            key.addEventListener('click', (e) => {
                e.stopPropagation();
                
                const htmlKey = key as HTMLElement;
                const indexAttr = htmlKey.getAttribute('data-index');
                const noteIndex = indexAttr ? parseInt(indexAttr) : NaN;
                if (isNaN(noteIndex)) return;

                playNote(frequencies[noteIndex], 0.5);

                const activeModeEl = document.querySelector('input[name="game-mode"]:checked') as HTMLInputElement | null;
                const activeMode = activeModeEl ? activeModeEl.value : 'practice';
                
                if (activeMode === 'test') {
                    const expectedPattern = targetScaleSteps.map(step => currentScaleId + step);
                    
                    if (scaleCompletedFlag && noteIndex === expectedPattern[0]) {
                        scaleCompletedFlag = false;
                        if (successResetTimeout) clearTimeout(successResetTimeout);
                        cleanPersonalKeyboardFeedbackStates();
                        userSequence = [];
                    }

                    if (userSequence.length === 0 && !scaleCompletedFlag) {
                        cleanPersonalKeyboardFeedbackStates();
                    }
                    
                    const expectedNoteIndex = expectedPattern[userSequence.length];

                    if (noteIndex === expectedNoteIndex) {
                        userSequence.push(noteIndex);
                        htmlKey.classList.add('test-correct'); 
                        updateInstructionsDashboard();
                        
                        if (userSequence.length === expectedPattern.length) {
                            score++;
                            scaleCompletedFlag = true;
                            
                            const scoreBox = document.getElementById('score-display');
                            if (scoreBox) {
                                scoreBox.textContent = String(score);
                                scoreBox.classList.add('score-bump');
                                setTimeout(() => scoreBox.classList.remove('score-bump'), 400);
                            }

                            const checkItem = document.querySelector(`#master-scales-checklist .checklist-item[data-scale-id="${currentScaleId}"]`);
                            if (checkItem) {
                                checkItem.classList.add('is-passed');
                            }
                            
                            triggerConfettiBurst();
                            updateInstructionsDashboard();
                            userSequence = [];

                            if (successResetTimeout) clearTimeout(successResetTimeout);
                            successResetTimeout = setTimeout(() => {
                                scaleCompletedFlag = false;
                                cleanPersonalKeyboardFeedbackStates(); 
                                updateInstructionsDashboard();
                            }, 5000);
                        }
                    } else {
                        htmlKey.classList.add('test-wrong'); 
                        
                        const correctDOMKey = document.querySelector(`#personal-piano .key[data-index="${expectedNoteIndex}"]`);
                        correctDOMKey?.classList.add('test-revealed');

                        userSequence = [];
                        updateInstructionsDashboard('error');
                        
                        if (errorResetTimeout) clearTimeout(errorResetTimeout);
                        errorResetTimeout = setTimeout(() => {
                            cleanPersonalKeyboardFeedbackStates();
                            updateInstructionsDashboard();
                        }, 1600);
                    }
                } else {
                    htmlKey.classList.add('user-active');
                    setTimeout(() => htmlKey.classList.remove('user-active'), 120);
                }
            });
        });

        updateDemoScaleHighlights();
        updateInstructionsDashboard();
    });
</script>

<style>
    :global(nav), :global(header), :global(.nav-bar), :global(.navbar), :global(.top-bar), :global(.site-header) {
        display: none !important;
    }

    .split-page-wrapper { width: 100%; display: flex; flex-direction: column; position: relative; }

    .portfolio-hero {
        height: 100dvh; width: 100%; display: flex; align-items: center; justify-content: center; text-align: center; position: relative; z-index: 5; padding: 0 2rem;
    }

    .hero-content-block { position: relative; z-index: 5; max-width: 750px; width: 100%; display: flex; flex-direction: column; align-items: center; gap: 1rem; }

    .page-title { 
        font-size: clamp(3.5rem, 12vw, 6rem); font-weight: 800; margin: 0; letter-spacing: -1px; color: #ffffff;
        text-shadow: 0 4px 16px rgba(0, 0, 0, 0.55); animation: scaleEase 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

