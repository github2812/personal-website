---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Brandon Naylor | Home">
	<div class="home-scroll-wrapper">
		<section class="hero-section">
			<canvas id="home-animation-canvas"></canvas>
			
			<div class="title-group">
				<h1 class="title">Brandon Naylor</h1>
				
				<div class="divider-container">
					<div class="divider-line"></div>
				</div>

				<p class="portfolio-text">Personal Website</p>
			</div>

			<div class="scroll-indicator">
				<p class="scroll-text">Scroll down for more info</p>
			</div>
		</section>

		<section class="about-section">
			<div class="about-container">
				<h2 class="about-title">About Me</h2>
				<p class="about-p">Template paragraph.</p>
			</div>
		</section>
	</div>
</Layout>

<script>
	const canvas = document.getElementById('home-animation-canvas') as HTMLCanvasElement;
	const ctx = canvas?.getContext('2d');

	function resizeCanvas() {
		if (canvas) {
			canvas.width = window.innerWidth;
			canvas.height = window.innerHeight;
		}
	}
	if (canvas) {
		resizeCanvas();
		window.addEventListener('resize', resizeCanvas);
	}

	const waveLayerCount = 4;
	let increment = 0;
	
	let waveXProgress = 0;
	const targetProgress = 1;
	const easeFactor = 0.012; 

	const particles: any[] = [];
	for (let i = 0; i < 18; i++) {
		particles.push({
			x: Math.random() * window.innerWidth,
			y: Math.random() * window.innerHeight,
			radius: Math.random() * 5 + 2,
			speed: Math.random() * 0.15 + 0.1,
			offset: Math.random() * Math.PI * 2,
			type: 'circle'
		});
	}
	for (let i = 0; i < 12; i++) {
		particles.push({
			x: Math.random() * window.innerWidth,
			y: Math.random() * window.innerHeight,
			size: Math.random() * 6 + 4,
			speed: Math.random() * 0.12 + 0.05,
			offset: Math.random() * Math.PI * 2,
			type: 'plus'
		});
	}

	function animateHome() {
		if (!ctx || !canvas) return;

		ctx.fillStyle = '#120924';
		ctx.fillRect(0, 0, canvas.width, canvas.height);

		const radialGlow = ctx.createRadialGradient(canvas.width/2, canvas.height/2, 10, canvas.width/2, canvas.height/2, canvas.width);
		radialGlow.addColorStop(0, '#2c1654');
		radialGlow.addColorStop(1, '#120924');
		ctx.fillStyle = radialGlow;
		ctx.fillRect(0, 0, canvas.width, canvas.height);

		const brightnessModifier = 0.7 + Math.sin(increment * 0.3) * 0.3;

		particles.forEach(p => {
			p.y -= p.speed;
			if (p.y < -10) p.y = canvas.height + 10;
			const currentX = p.x + Math.sin(increment * 0.5 + p.offset) * 15;

			if (p.type === 'circle') {
				ctx.beginPath();
				ctx.arc(currentX, p.y, p.radius, 0, Math.PI * 2);
				ctx.fillStyle = `rgba(188, 52, 164, ${0.4 * brightnessModifier})`;
				ctx.fill();
			} else {
				ctx.beginPath();
				ctx.moveTo(currentX - p.size, p.y);
				ctx.lineTo(currentX + p.size, p.y);
				ctx.moveTo(currentX, p.y - p.size);
				ctx.lineTo(currentX, p.y + p.size);
				ctx.strokeStyle = `rgba(139, 92, 246, ${0.5 * brightnessModifier})`;
				ctx.lineWidth = p.size * 0.45; 
				ctx.stroke();
			}
		});

		if (waveXProgress < targetProgress) {
			waveXProgress += (targetProgress - waveXProgress) * easeFactor;
		}

		// Shifted the entire wave rendering up by 5 pixels (now just +5 instead of +10)
		const baseYOffset = (canvas.height * 0.42) + 5;

		for (let i = 0; i < waveLayerCount; i++) {
			ctx.beginPath();
			
			const baseAlpha = 0.8 - (i * 0.15);
			const alpha = baseAlpha * brightnessModifier;
			ctx.strokeStyle = i % 2 === 0 ? `rgba(139, 92, 246, ${alpha})` : `rgba(217, 70, 239, ${alpha})`;
			
			ctx.lineWidth = 2.0 - (i * 0.3);

			const drawWidthLimit = canvas.width * waveXProgress;

			for (let x = 0; x <= drawWidthLimit; x += 2) {
				
				const freq1 = Math.sin(x * (0.04 + (i * 0.01)) + (increment * (4 + i)));
				const freq2 = Math.cos(x * 0.07 - (increment * 2));
				const signal = freq1 * freq2;

				const rawEnv = Math.sin(x * 0.0025 - increment + (i * 0.5));
				const envelope = Math.pow(rawEnv, 2); 

				const maxAmplitude = 120 - (i * 15);
				const finalAmplitude = maxAmplitude * envelope * signal;

				const y = baseYOffset + finalAmplitude;
				
				if (x === 0) ctx.moveTo(x, y);
				else ctx.lineTo(x, y);
			}
			ctx.stroke();
		}

		increment += 0.0025;
		requestAnimationFrame(animateHome);
	}

	if (canvas) animateHome();
</script>

<style>
	.home-scroll-wrapper {
		display: flex;
		flex-direction: column;
		width: 100%;
		position: relative;
	}

	.hero-section {
		height: 100vh;
		width: 100%;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		text-align: center;
		position: relative;
		z-index: 2;
		overflow: hidden;
	}

	#home-animation-canvas {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 1;
		pointer-events: none;
	}

	.title-group {
		position: relative;
		z-index: 5;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
	}

	.title {
		font-family: 'Poppins', sans-serif;
		font-size: 5rem;
		font-weight: 700;
		margin: 0;
		color: #ffffff;
		line-height: 1.1;
		text-shadow: 
			0px 2px 4px rgba(0, 0, 0, 0.9),
			0px 10px 30px rgba(0, 0, 0, 0.9);
		animation: scaleEase 1.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		will-change: transform, opacity;
		opacity: 0;
	}

	.divider-container {
		width: 100%;
		max-width: 800px;
		height: 3px;
		margin: calc(1rem + 15px) 0 1rem 0; 
		display: flex;
		justify-content: center;
		align-items: center;
		position: relative;
		z-index: 10;
		filter: drop-shadow(0px 4px 12px rgba(0, 0, 0, 0.95));
	}
	
	.divider-line {
		height: 3px;
		width: 100%;
		background: linear-gradient(90deg, transparent 10%, #ffffff 50%, transparent 90%);
		animation: lineGrow 1.4s cubic-bezier(0.25, 1, 0.5, 1) 0.6s forwards;
		will-change: max-width;
		max-width: 0%;
	}

	.portfolio-text {
		font-family: 'Poppins', sans-serif;
		font-size: 2.8rem;
		font-weight: 300;
		color: #ffffff;
		margin: 0;
		opacity: 0;
		letter-spacing: 4px;
		text-shadow: 
			0px 2px 4px rgba(0, 0, 0, 0.8),
			0px 8px 25px rgba(0, 0, 0, 0.85);
		animation: scaleEase 1.8s cubic-bezier(0.16, 1, 0.3, 1) 0.8s forwards;
		will-change: transform, opacity;
	}

	.scroll-indicator {
		position: absolute;
		bottom: 3rem;
		left: 0;
		width: 100%;
		display: flex;
		justify-content: center;
		align-items: center;
		overflow: hidden; 
		padding-top: 10px;
		z-index: 5;
	}
	
	.scroll-text {
		font-family: 'Poppins', sans-serif;
		font-size: 0.85rem; 
		font-weight: 400;
		color: #ffffff;
		margin: 0;
		opacity: 0;
		letter-spacing: 2.5px;
		text-transform: uppercase;
		text-shadow: 0px 4px 12px rgba(0, 0, 0, 0.9);
		animation: slideUpFromBottom 1.2s cubic-bezier(0.16, 1, 0.3, 1) 1.5s forwards;
		will-change: transform, opacity;
	}

	.about-section {
		background-color: #d8d8de; 
		color: #120924; 
		min-height: 80vh;
		width: 100%;
		position: relative;
		z-index: 10; 
		display: flex;
		justify-content: center;
		align-items: center;
		padding: 6rem 2rem;
		box-sizing: border-box;
		box-shadow: 0 -15px 30px rgba(0, 0, 0, 0.12); 
	}

	.about-container {
		max-width: 800px;
		width: 100%;
		text-align: left;
	}

	.about-title {
		font-family: 'Poppins', sans-serif;
		font-size: 3rem;
		font-weight: 700;
		margin: 0 0 1.5rem 0;
	}

	.about-p {
		font-family: 'Poppins', sans-serif;
		font-size: 1.15rem;
		line-height: 1.7;
		opacity: 0.85;
		margin: 0;
	}

	@keyframes scaleEase {
		from { opacity: 0; transform: scale(0.92); }
		to { opacity: 1; transform: scale(1); }
	}
	
	@keyframes lineGrow {
		from { max-width: 0%; }
		to { max-width: 100%; }
	}
	
	@keyframes slideUpFromBottom {
		from {
			opacity: 0;
			transform: translateY(30px); 
		}
		to {
			opacity: 0.7;
			transform: translateY(0);
		}
	}

	@media (max-width: 768px) {
		.title { font-size: 3.2rem; }
		.portfolio-text { font-size: 2rem; }
		.scroll-text { font-size: 0.7rem; }
	}
</style>