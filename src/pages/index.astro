---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Brandon Naylor | Home">
	<div class="hero-container">
		<h1 class="title">Brandon Naylor</h1>
		<div class="divider"></div>
		<p class="subtitle">Portfolio</p>
	</div>
</Layout>

<style>
	.hero-container {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		text-align: center;
		padding: 2rem;
		box-sizing: border-box;
	}
	.title {
		font-family: 'Poppins', sans-serif;
		font-size: 5rem;
		font-weight: 700;
		margin: 0;
		color: #ffffff;
		line-height: 1.1;
	}
	.divider {
		height: 3px;
		width: 100%;
		max-width: 600px;
		background: linear-gradient(90deg, transparent 10%, #bc34a4 50%, transparent 90%);
		margin: 1.5rem 0;
	}
	.subtitle {
		font-family: 'Poppins', sans-serif;
		font-size: 3.5rem;
		font-weight: 300;
		color: #ffffff;
		margin: 0;
	}

	@media (max-width: 768px) {
		.title { font-size: 3rem; }
		.subtitle { font-size: 1.8rem; }
	}
</style>